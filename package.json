{
  "name": "no-duplicate-chrome-tabs",
  "version": "1.1.1",
  "description": "Chrome extension to prevent duplicate tabs by focusing existing tabs",
  "main": "dist/background.js",
  "scripts": {
    "build": "TS_NODE_PROJECT=tsconfig.node.json webpack --config webpack.dev.config.ts && cp manifest.json dist/",
    "build:prod": "TS_NODE_PROJECT=tsconfig.node.json webpack --config webpack.config.ts && cp manifest.json dist/ && cp -r icons dist/ 2>/dev/null || true",
    "build:watch": "TS_NODE_PROJECT=tsconfig.node.json webpack --config webpack.dev.config.ts --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run test:ci",
    "clean": "rm -rf dist extension.zip",
    "prepack": "npm run clean && npm run build:prod",
    "zip": "npm run build:prod && cd dist && zip -r ../extension.zip ."
  },
  "keywords": [
    "chrome-extension",
    "tabs",
    "duplicate"
  ],
  "author": "Viking Jonsson",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.0.328",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.7",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.2",
    "lint-staged": "^15.5.2",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run validate"
    }
  }
}
