{
  "name": "no-duplicate-chrome-tabs",
  "version": "1.1.1",
  "description": "Chrome extension to prevent duplicate tabs by focusing existing tabs",
  "main": "dist/background.js",
  "scripts": {
    "build": "TS_NODE_PROJECT=tsconfig.node.json webpack --config webpack.dev.config.ts && cp manifest.json dist/",
    "build:prod": "TS_NODE_PROJECT=tsconfig.node.json webpack --config webpack.config.ts && cp manifest.json dist/ && cp -r icons dist/ 2>/dev/null || true",
    "build:watch": "TS_NODE_PROJECT=tsconfig.node.json webpack --config webpack.dev.config.ts --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run test:ci",
    "clean": "rm -rf dist extension.zip",
    "prepack": "npm run clean && npm run build:prod",
    "zip": "npm run build:prod && cd dist && zip -r ../extension.zip ."
  },
  "keywords": [
    "chrome-extension",
    "tabs",
    "duplicate"
  ],
  "author": "Viking Jonsson",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "0.1.38",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.0",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-prettier": "5.5.5",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "webpack": "5.105.4",
    "webpack-cli": "7.0.2"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run validate"
    }
  }
}
